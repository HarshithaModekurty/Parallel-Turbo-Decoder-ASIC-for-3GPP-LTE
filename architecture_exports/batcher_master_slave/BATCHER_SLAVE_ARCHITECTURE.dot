digraph batcher_slave_arch {
  graph [
    rankdir=LR,
    splines=polyline,
    nodesep=0.4,
    ranksep=0.7,
    pad=0.2,
    bgcolor="white",
    fontname="Helvetica",
    labelloc="t",
    label="batcher_slave Architecture"
  ];
  node [shape=box, style="rounded,filled", fillcolor="white", color="#334155", fontname="Helvetica", fontsize=10, margin="0.10,0.06"];
  edge [color="#475569", arrowsize=0.7, penwidth=1.1, fontname="Helvetica", fontsize=9];

  perm_in [label="perm_in[0..G_P-1]", fillcolor="#F8FAFC"];
  data_in [label="data_in[0..G_P-1]", fillcolor="#F8FAFC"];
  data_out [label="data_out[0..G_P-1]", fillcolor="#F8FAFC"];

  subgraph cluster_unpack {
    label="Unpack / Init";
    color="#93C5FD";
    style="rounded";
    unpack [label="unpack data_in -> in_v(i)", fillcolor="#EFF6FF"];
    zero_out [label="initialize out_v(i)=0", fillcolor="#EFF6FF"];
  }

  subgraph cluster_core {
    label="Permutation Core";
    color="#FCD34D";
    style="rounded";
    decode [label="decode perm_i\nto_integer(to_01(...))", fillcolor="#FFFBEB"];
    mode [label="mode select\nG_REVERSE", fillcolor="#FFFBEB"];
    route [label="assignment network\nforward:\nout_v(perm_i)=in_v(slot)\nreverse:\nout_v(slot)=in_v(perm_i)", fillcolor="#FFFBEB"];
    guard [label="bounds guard\n0 <= perm_i < G_P", fillcolor="#FFFBEB"];
  }

  subgraph cluster_pack {
    label="Output Pack";
    color="#A7F3D0";
    style="rounded";
    repack [label="pack out_v -> d_tmp", fillcolor="#F0FDF4"];
  }

  note0 [shape=note, fillcolor="#FEFCE8", color="#EAB308", label="The slave is a payload crossbar.\n`perm_in` supplies the mapping.\n`G_REVERSE` chooses direction."];

  data_in -> unpack;
  perm_in -> decode;
  unpack -> route [label="in_v"];
  zero_out -> route [label="out_v init"];
  decode -> guard;
  mode -> route [style=dashed, color="#2563EB", label="forward / reverse"];
  guard -> route [label="valid perm_i only"];
  route -> repack [label="out_v"];
  repack -> data_out;
  note0 -> route [style=dotted, arrowhead=none, color="#A16207"];
}
