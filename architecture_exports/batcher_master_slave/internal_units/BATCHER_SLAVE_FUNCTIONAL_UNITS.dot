digraph batcher_slave_units {
  graph [
    rankdir=LR,
    splines=polyline,
    nodesep=0.4,
    ranksep=0.7,
    pad=0.2,
    bgcolor="white",
    fontname="Helvetica",
    labelloc="t",
    label="batcher_slave Internal Functional Units"
  ];
  node [shape=box, style="rounded,filled", fillcolor="white", color="#334155", fontname="Helvetica", fontsize=10, margin="0.10,0.06"];
  edge [color="#475569", arrowsize=0.7, penwidth=1.1, fontname="Helvetica", fontsize=9];

  perm_in [label="perm_in[0..G_P-1]", fillcolor="#F8FAFC"];
  data_in [label="data_in[0..G_P-1]", fillcolor="#F8FAFC"];
  data_out [label="data_out[0..G_P-1]", fillcolor="#F8FAFC"];

  subgraph cluster_unpack {
    label="Unpack / Init";
    color="#93C5FD";
    style="rounded";
    unpack [label="unpack data_in -> in_v", fillcolor="#EFF6FF"];
    zero [label="initialize out_v=0", fillcolor="#EFF6FF"];
  }

  subgraph cluster_decode {
    label="Per-Slot Decode Units";
    color="#FCD34D";
    style="rounded";
    decode [label="decode perm_i from perm_in(slot)", fillcolor="#FFFBEB"];
    check [label="bounds check\n0 <= perm_i < G_P", fillcolor="#FFFBEB"];
    mode [label="mode select\nG_REVERSE", fillcolor="#FFFBEB"];
  }

  subgraph cluster_route {
    label="Permutation Router Network";
    color="#F59E0B";
    style="rounded";
    router [label="replicated slot-router cells\nforward or reverse", fillcolor="#FFFBEB"];
  }

  subgraph cluster_pack {
    label="Output Pack";
    color="#A7F3D0";
    style="rounded";
    repack [label="pack out_v -> data_out", fillcolor="#F0FDF4"];
  }

  note0 [shape=note, fillcolor="#FEFCE8", color="#EAB308", label="Purely combinational crossbar.\nNo sorting. Only permutation decode and routing."];

  data_in -> unpack;
  perm_in -> decode;
  decode -> check;
  mode -> router [style=dashed, color="#2563EB", label="forward / reverse"];
  unpack -> router [label="in_v"];
  zero -> router [label="out_v init"];
  check -> router [label="valid assignments only"];
  router -> repack;
  repack -> data_out;
  note0 -> router [style=dotted, arrowhead=none, color="#A16207"];
}
