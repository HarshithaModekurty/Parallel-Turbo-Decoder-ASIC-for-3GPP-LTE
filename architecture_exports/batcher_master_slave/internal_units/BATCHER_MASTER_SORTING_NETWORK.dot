digraph batcher_master_net {
  graph [
    rankdir=LR,
    splines=polyline,
    nodesep=0.35,
    ranksep=0.75,
    pad=0.2,
    bgcolor="white",
    fontname="Helvetica",
    labelloc="t",
    label="batcher_master 6-Stage Sorting Network"
  ];
  node [shape=box, style="rounded,filled", fillcolor="white", color="#334155", fontname="Helvetica", fontsize=10, margin="0.10,0.06"];
  edge [color="#475569", arrowsize=0.7, penwidth=1.1, fontname="Helvetica", fontsize=9];

  inpair [label="addr_v + lane_v input vectors", fillcolor="#F8FAFC"];

  s0 [label="Stage 0\ncs(0,1)->c0\ncs(2,3)->c1\ncs(4,5)->c2\ncs(6,7)->c3", fillcolor="#FFFBEB"];
  s1 [label="Stage 1\ncs(0,2)->c4\ncs(1,3)->c5\ncs(4,6)->c6\ncs(5,7)->c7", fillcolor="#FFFBEB"];
  s2 [label="Stage 2\ncs(1,2)->c8\ncs(5,6)->c9", fillcolor="#FFFBEB"];
  s3 [label="Stage 3\ncs(0,4)->c10\ncs(1,5)->c11\ncs(2,6)->c12\ncs(3,7)->c13", fillcolor="#FFFBEB"];
  s4 [label="Stage 4\ncs(2,4)->c14\ncs(3,5)->c15", fillcolor="#FFFBEB"];
  s5 [label="Stage 5\ncs(1,2)->c16\ncs(3,4)->c17\ncs(5,6)->c18", fillcolor="#FFFBEB"];

  outpair [label="sorted addr_v + lane_v", fillcolor="#F8FAFC"];
  ctrl [label="ctrl_out[18:0]\nconcatenated swap history", fillcolor="#F8FAFC"];

  note0 [shape=note, fillcolor="#FEFCE8", color="#EAB308", label="This is the actual fixed compare-swap schedule\nhard-coded in batcher_master.vhd."];

  inpair -> s0 -> s1 -> s2 -> s3 -> s4 -> s5 -> outpair;
  s0 -> ctrl [label="c0..c3"];
  s1 -> ctrl [label="c4..c7"];
  s2 -> ctrl [label="c8..c9"];
  s3 -> ctrl [label="c10..c13"];
  s4 -> ctrl [label="c14..c15"];
  s5 -> ctrl [label="c16..c18"];
  note0 -> s3 [style=dotted, arrowhead=none, color="#A16207"];
}
