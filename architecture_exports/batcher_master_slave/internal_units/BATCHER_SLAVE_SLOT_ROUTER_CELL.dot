digraph batcher_slave_cell {
  graph [
    rankdir=LR,
    splines=polyline,
    nodesep=0.35,
    ranksep=0.7,
    pad=0.2,
    bgcolor="white",
    fontname="Helvetica",
    labelloc="t",
    label="batcher_slave Per-Slot Router Cell"
  ];
  node [shape=box, style="rounded,filled", fillcolor="white", color="#334155", fontname="Helvetica", fontsize=10, margin="0.10,0.06"];
  edge [color="#475569", arrowsize=0.7, penwidth=1.1, fontname="Helvetica", fontsize=9];

  slot [label="slot index", fillcolor="#F8FAFC"];
  perm [label="perm_in(slot)", fillcolor="#F8FAFC"];
  inv [label="in_v(slot)", fillcolor="#F8FAFC"];
  array_in [label="in_v(perm_i)", fillcolor="#F8FAFC"];

  decode [label="perm_i = decode(perm_in(slot))", fillcolor="#FFFBEB"];
  check [label="valid = (0 <= perm_i < G_P)", fillcolor="#FFFBEB"];
  mode [label="G_REVERSE", fillcolor="#EFF6FF"];
  select [label="assignment select\nforward: out_v(perm_i)=in_v(slot)\nreverse: out_v(slot)=in_v(perm_i)", fillcolor="#FFFBEB"];
  enable [label="gated write/assignment\nonly if valid", fillcolor="#F0FDF4"];

  note0 [shape=note, fillcolor="#FEFCE8", color="#EAB308", label="This is the slave's deep primitive.\nA decoded permutation index plus a mode bit\nselect the assignment direction."];

  perm -> decode -> check -> enable;
  mode -> select [style=dashed, color="#2563EB"];
  slot -> select;
  inv -> select;
  array_in -> select;
  select -> enable;
  note0 -> select [style=dotted, arrowhead=none, color="#A16207"];
}
