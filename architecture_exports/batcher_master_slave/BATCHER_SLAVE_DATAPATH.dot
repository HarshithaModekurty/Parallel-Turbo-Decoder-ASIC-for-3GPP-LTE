digraph batcher_slave_data {
  graph [
    rankdir=LR,
    splines=polyline,
    nodesep=0.35,
    ranksep=0.7,
    pad=0.2,
    bgcolor="white",
    fontname="Helvetica",
    labelloc="t",
    label="batcher_slave Datapath"
  ];
  node [shape=box, style="rounded,filled", fillcolor="white", color="#334155", fontname="Helvetica", fontsize=10, margin="0.10,0.06"];
  edge [color="#475569", arrowsize=0.7, penwidth=1.1, fontname="Helvetica", fontsize=9];

  data_in [label="data_in bus", fillcolor="#F8FAFC"];
  in_lanes [label="in_v[0..G_P-1]", fillcolor="#EFF6FF"];
  crossbar [label="lane crossbar / assignment network", fillcolor="#FFFBEB"];
  out_lanes [label="out_v[0..G_P-1]", fillcolor="#EFF6FF"];
  data_out [label="data_out bus", fillcolor="#F8FAFC"];

  note0 [shape=note, fillcolor="#FEFCE8", color="#EAB308", label="Datapath flow:\nunpack -> permute lanes -> repack"];

  data_in -> in_lanes -> crossbar -> out_lanes -> data_out;
  note0 -> crossbar [style=dotted, arrowhead=none, color="#A16207"];
}
