digraph batcher_master_arch {
  graph [
    rankdir=LR,
    splines=polyline,
    nodesep=0.4,
    ranksep=0.7,
    pad=0.2,
    bgcolor="white",
    fontname="Helvetica",
    labelloc="t",
    label="batcher_master Architecture"
  ];
  node [shape=box, style="rounded,filled", fillcolor="white", color="#334155", fontname="Helvetica", fontsize=10, margin="0.10,0.06"];
  edge [color="#475569", arrowsize=0.7, penwidth=1.1, fontname="Helvetica", fontsize=9];

  in_addr [label="addr_in[0..7]", fillcolor="#F8FAFC"];
  out_addr [label="addr_sorted[0..7]", fillcolor="#F8FAFC"];
  out_perm [label="perm_out[0..7]", fillcolor="#F8FAFC"];
  out_ctrl [label="ctrl_out[18:0]", fillcolor="#F8FAFC"];

  subgraph cluster_init {
    label="Initialization";
    color="#93C5FD";
    style="rounded";
    unpack [label="unpack addr_in\naddr_v(i)", fillcolor="#EFF6FF"];
    tags [label="initialize lane_v(i)=i", fillcolor="#EFF6FF"];
  }

  subgraph cluster_net {
    label="6-Stage Batcher Network";
    color="#FCD34D";
    style="rounded";
    s0 [label="Stage 0\n(0,1) (2,3) (4,5) (6,7)", fillcolor="#FFFBEB"];
    s1 [label="Stage 1\n(0,2) (1,3) (4,6) (5,7)", fillcolor="#FFFBEB"];
    s2 [label="Stage 2\n(1,2) (5,6)", fillcolor="#FFFBEB"];
    s3 [label="Stage 3\n(0,4) (1,5) (2,6) (3,7)", fillcolor="#FFFBEB"];
    s4 [label="Stage 4\n(2,4) (3,5)", fillcolor="#FFFBEB"];
    s5 [label="Stage 5\n(1,2) (3,4) (5,6)", fillcolor="#FFFBEB"];
  }

  subgraph cluster_out {
    label="Output Packing";
    color="#A7F3D0";
    style="rounded";
    pack_a [label="pack addr_v -> a_tmp", fillcolor="#F0FDF4"];
    pack_p [label="pack lane_v -> p_tmp", fillcolor="#F0FDF4"];
    ctrl_pack [label="c_tmp -> ctrl_out", fillcolor="#F0FDF4"];
  }

  note0 [shape=note, fillcolor="#FEFCE8", color="#EAB308", label="Specialized for G_P = 8.\nEach compare-swap updates both\naddress values and lane tags."];

  in_addr -> unpack;
  tags -> s0 [label="lane_v"];
  unpack -> s0 [label="addr_v"];
  s0 -> s1;
  s1 -> s2;
  s2 -> s3;
  s3 -> s4;
  s4 -> s5;
  s5 -> pack_a [label="final addr_v"];
  s5 -> pack_p [label="final lane_v"];
  s5 -> ctrl_pack [label="swap decisions"];
  pack_a -> out_addr;
  pack_p -> out_perm;
  ctrl_pack -> out_ctrl;
  note0 -> s3 [style=dotted, arrowhead=none, color="#A16207"];
}
