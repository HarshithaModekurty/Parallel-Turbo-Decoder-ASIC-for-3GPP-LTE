digraph BATCHER_MASTER_SORTING_NETWORK_CELL_LEVEL {
  graph [rankdir=TB, splines=polyline, nodesep=0.45, ranksep=0.7, bgcolor="white", fontname="Helvetica"];
  node [fontname="Helvetica", fontsize=10, style="rounded,filled", color="#1f4e79", fillcolor="#eef5fb", shape=box];
  edge [fontname="Helvetica", fontsize=9, color="#1f4e79", arrowsize=0.7];

  title [shape=plaintext, label="batcher_master: 19-Cell Sorting Network Replication"];
  note [shape=note, fillcolor="#fff4cc", color="#9c6500",
        label="Each stage is built from the compare-swap cell.\nThe figure shows repeated cells with ... where convenient.\nTotal cells = 19."];

  inbus [shape=parallelogram, fillcolor="#d9ebf7", label="addr_v(0..7)\nlane_v(0..7)"];

  s0a [label="Stage 0\nCS(0,1)\nCell 0"];
  s0b [label="Stage 0\nCS(2,3)\nCell 1"];
  s0dots [shape=plaintext, label="..."];
  s0d [label="Stage 0\nCS(6,7)\nCell 3\n4 total"];

  s1a [label="Stage 1\nCS(0,2)\nCell 4"];
  s1b [label="Stage 1\nCS(1,3)\nCell 5"];
  s1dots [shape=plaintext, label="..."];
  s1d [label="Stage 1\nCS(5,7)\nCell 7\n4 total"];

  s2a [label="Stage 2\nCS(1,2)\nCell 8"];
  s2dots [shape=plaintext, label="..."];
  s2b [label="Stage 2\nCS(5,6)\nCell 9\n2 total"];

  s3a [label="Stage 3\nCS(0,4)\nCell 10"];
  s3b [label="Stage 3\nCS(1,5)\nCell 11"];
  s3dots [shape=plaintext, label="..."];
  s3d [label="Stage 3\nCS(3,7)\nCell 13\n4 total"];

  s4a [label="Stage 4\nCS(2,4)\nCell 14"];
  s4dots [shape=plaintext, label="..."];
  s4b [label="Stage 4\nCS(3,5)\nCell 15\n2 total"];

  s5a [label="Stage 5\nCS(1,2)\nCell 16"];
  s5b [label="Stage 5\nCS(3,4)\nCell 17"];
  s5dots [shape=plaintext, label="..."];
  s5c [label="Stage 5\nCS(5,6)\nCell 18\n3 total"];

  ctrl [shape=parallelogram, fillcolor="#fce4d6", color="#c55a11",
        label="ctrl_out = {c[0], c[1], ..., c[18]}"];
  outbus [shape=parallelogram, fillcolor="#d9ebf7", label="addr_sorted\nperm_out"];

  {rank=same; s0a s0b s0dots s0d}
  {rank=same; s1a s1b s1dots s1d}
  {rank=same; s2a s2dots s2b}
  {rank=same; s3a s3b s3dots s3d}
  {rank=same; s4a s4dots s4b}
  {rank=same; s5a s5b s5dots s5c}

  title -> note [style=invis];
  note -> inbus;

  inbus -> s0a;
  inbus -> s0b;
  inbus -> s0d;

  s0a -> s1a;
  s0b -> s1b;
  s0d -> s1d;

  s1a -> s2a;
  s1d -> s2b;

  s2a -> s3a;
  s2a -> s3b;
  s2b -> s3d;

  s3a -> s4a;
  s3d -> s4b;

  s4a -> s5a;
  s4a -> s5b;
  s4b -> s5c;

  s0a -> ctrl [style=dashed, label="c[0:3]"];
  s1a -> ctrl [style=dashed, label="c[4:7]"];
  s2a -> ctrl [style=dashed, label="c[8:9]"];
  s3a -> ctrl [style=dashed, label="c[10:13]"];
  s4a -> ctrl [style=dashed, label="c[14:15]"];
  s5a -> ctrl [style=dashed, label="c[16:18]"];

  s5a -> outbus;
  s5b -> outbus;
  s5c -> outbus;
}
