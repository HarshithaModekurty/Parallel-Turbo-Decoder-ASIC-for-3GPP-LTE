digraph batcher_slave_ctrl {
  graph [
    rankdir=TB,
    splines=polyline,
    nodesep=0.35,
    ranksep=0.6,
    pad=0.2,
    bgcolor="white",
    fontname="Helvetica",
    labelloc="t",
    label="batcher_slave Control Structure"
  ];
  node [shape=box, style="rounded,filled", fillcolor="white", color="#334155", fontname="Helvetica", fontsize=10, margin="0.10,0.06"];
  edge [color="#475569", arrowsize=0.7, penwidth=1.1, fontname="Helvetica", fontsize=9];

  decode [label="Per-slot Control\nperm_i = to_integer(to_01(perm_in(slot)))", fillcolor="#FFFBEB"];
  guard [label="Bounds Check\nif 0 <= perm_i < G_P", fillcolor="#F8FBFF"];
  mode [label="Mode Control\nG_REVERSE = false:\nout_v(perm_i)=in_v(slot)\nG_REVERSE = true:\nout_v(slot)=in_v(perm_i)", fillcolor="#EFF6FF"];
  route [label="Enabled assignment into out_v", fillcolor="#F0FDF4"];

  note0 [shape=note, fillcolor="#FEF2F2", color="#F87171", label="No sequential control.\nThe only control is permutation decode,\nmode selection, and bounds gating."];

  decode -> guard -> route;
  mode -> route [style=dashed, color="#2563EB", label="select assignment direction"];
  note0 -> mode [style=dotted, arrowhead=none, color="#DC2626"];
}
