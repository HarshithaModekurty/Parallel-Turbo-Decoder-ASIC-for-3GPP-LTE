digraph G {
  rankdir=TB;
  splines=ortho;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Shared Radix-4 ACS, Isomorphic Cell View"];
  node [fontname="Helvetica", fontsize=9, color="#444444"];
  edge [fontname="Helvetica", fontsize=8, color="#444444", arrowsize=0.7];

  statein [shape=cylinder, style="filled", fillcolor="#ead1dc", label="state_in\n8 x 10b\nalpha_work or beta_work"];
  gammain [shape=cylinder, style="filled", fillcolor="#ead1dc", label="gamma_in\n16 x 10b"];
  mode [shape=box, style="rounded,filled", fillcolor="#fff2cc", label="mode\nforward / backward"];

  subgraph cluster_s0 {
    label="ACS state cell 0 (1 of 8)";
    color="#6fa8dc";
    style="rounded";

    mux0 [shape=trapezium, style="filled", fillcolor="#fff2cc", label="MUX x4\npath select"];
    a00 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    a01 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    a02 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    a03 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    m00 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    m01 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    m02 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    r0 [shape=box3d, style="filled", fillcolor="#ead1dc", label="ret[0]\n10b"];

    mux0 -> a00;
    mux0 -> a01;
    mux0 -> a02;
    mux0 -> a03;
    a00 -> m00;
    a01 -> m00;
    a02 -> m01;
    a03 -> m01;
    m00 -> m02;
    m01 -> m02;
    m02 -> r0;
  }

  subgraph cluster_s1 {
    label="ACS state cell 1 (2 of 8)";
    color="#6fa8dc";
    style="rounded";

    mux1 [shape=trapezium, style="filled", fillcolor="#fff2cc", label="MUX x4"];
    a10 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    a11 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    a12 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    a13 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    m10 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    m11 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    m12 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    r1 [shape=box3d, style="filled", fillcolor="#ead1dc", label="ret[1]"];

    mux1 -> a10;
    mux1 -> a11;
    mux1 -> a12;
    mux1 -> a13;
    a10 -> m10;
    a11 -> m10;
    a12 -> m11;
    a13 -> m11;
    m10 -> m12;
    m11 -> m12;
    m12 -> r1;
  }

  dots [shape=plaintext, label="...\nstate cells 2 to 6 omitted\nsame MUX + 4 adders + 3 MAX blocks"];

  subgraph cluster_s7 {
    label="ACS state cell 7 (8 of 8)";
    color="#6fa8dc";
    style="rounded";

    mux7 [shape=trapezium, style="filled", fillcolor="#fff2cc", label="MUX x4"];
    a70 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    a71 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    a72 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    a73 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.36, fixedsize=true, label="+"];
    m70 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    m71 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    m72 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    r7 [shape=box3d, style="filled", fillcolor="#ead1dc", label="ret[7]"];

    mux7 -> a70;
    mux7 -> a71;
    mux7 -> a72;
    mux7 -> a73;
    a70 -> m70;
    a71 -> m70;
    a72 -> m71;
    a73 -> m71;
    m70 -> m72;
    m71 -> m72;
    m72 -> r7;
  }

  stateout [shape=cylinder, style="filled", fillcolor="#ead1dc", label="state_out\n8 x 10b\nlatched into alpha_work or beta_work"];
  note [shape=note, style="filled", fillcolor="#fff2cc", label="Full ACS totals:\n8 repeated state cells\n32 adders\n8 MUX-x4 blocks\n24 compare-select blocks"];

  statein -> mux0;
  gammain -> mux0;
  mode -> mux0;

  statein -> mux1;
  gammain -> mux1;
  mode -> mux1;

  statein -> dots [style=dashed];
  gammain -> dots [style=dashed];
  mode -> dots [style=dashed];

  statein -> mux7;
  gammain -> mux7;
  mode -> mux7;

  r0 -> stateout;
  r1 -> stateout;
  dots -> stateout [style=dashed];
  r7 -> stateout;
  stateout -> note;
}
