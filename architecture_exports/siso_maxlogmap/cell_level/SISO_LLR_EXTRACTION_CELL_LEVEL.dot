digraph G {
  rankdir=TB;
  splines=ortho;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - LLR Extraction, Isomorphic Cell View"];
  node [fontname="Helvetica", fontsize=9, color="#444444"];
  edge [fontname="Helvetica", fontsize=8, color="#444444", arrowsize=0.7];

  areg [shape=cylinder, style="filled", fillcolor="#ead1dc", label="alpha_in\n8 x 10b"];
  breg [shape=cylinder, style="filled", fillcolor="#ead1dc", label="beta_in\n8 x 10b"];
  g0reg [shape=cylinder, style="filled", fillcolor="#ead1dc", label="g0\n4 x 10b"];
  g1reg [shape=cylinder, style="filled", fillcolor="#ead1dc", label="g1\n4 x 10b"];
  sysreg [shape=cylinder, style="filled", fillcolor="#ead1dc", label="sys_even / sys_odd"];
  apreg [shape=cylinder, style="filled", fillcolor="#ead1dc", label="apri_even / apri_odd"];

  subgraph cluster_alpha {
    label="alpha_mid reconstruction";
    color="#93c47d";
    style="rounded";

    aa0 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    aa1 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    amx0 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    amid0 [shape=box3d, style="filled", fillcolor="#ead1dc", label="alpha_mid[0]"];

    aa2 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    aa3 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    amx1 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    amid1 [shape=box3d, style="filled", fillcolor="#ead1dc", label="alpha_mid[1]"];

    adots [shape=plaintext, label="...\n8 cells total\n2 adders + 1 MAX each"];
    amid7 [shape=box3d, style="filled", fillcolor="#ead1dc", label="alpha_mid[7]"];

    areg -> aa0;
    g0reg -> aa0;
    areg -> aa1;
    g0reg -> aa1;
    aa0 -> amx0;
    aa1 -> amx0;
    amx0 -> amid0;

    areg -> aa2;
    g0reg -> aa2;
    areg -> aa3;
    g0reg -> aa3;
    aa2 -> amx1;
    aa3 -> amx1;
    amx1 -> amid1;

    adots -> amid7 [style=dashed];
  }

  subgraph cluster_beta {
    label="beta_mid reconstruction";
    color="#93c47d";
    style="rounded";

    ba0 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    ba1 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    bmx0 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    bmid0 [shape=box3d, style="filled", fillcolor="#ead1dc", label="beta_mid[0]"];

    ba2 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    ba3 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    bmx1 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    bmid1 [shape=box3d, style="filled", fillcolor="#ead1dc", label="beta_mid[1]"];

    bdots [shape=plaintext, label="...\n8 cells total\n2 adders + 1 MAX each"];
    bmid7 [shape=box3d, style="filled", fillcolor="#ead1dc", label="beta_mid[7]"];

    breg -> ba0;
    g1reg -> ba0;
    breg -> ba1;
    g1reg -> ba1;
    ba0 -> bmx0;
    ba1 -> bmx0;
    bmx0 -> bmid0;

    breg -> ba2;
    g1reg -> ba2;
    breg -> ba3;
    g1reg -> ba3;
    ba2 -> bmx1;
    ba3 -> bmx1;
    bmx1 -> bmid1;

    bdots -> bmid7 [style=dashed];
  }

  subgraph cluster_even {
    label="even-bit metric and max tree";
    color="#6fa8dc";
    style="rounded";

    e0a [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    e0b [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    e0y [shape=box3d, style="filled", fillcolor="#ead1dc", label="cand u0=0"];
    e1a [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    e1b [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    e1y [shape=box3d, style="filled", fillcolor="#ead1dc", label="cand u0=1"];
    edots [shape=plaintext, label="...\n16 candidate chains total\n2 adders each"];

    em0 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    em1 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    emf [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    max0 [shape=box3d, style="filled", fillcolor="#ead1dc", label="max0_u0"];
    max1 [shape=box3d, style="filled", fillcolor="#ead1dc", label="max1_u0"];

    areg -> e0a;
    g0reg -> e0a;
    bmid0 -> e0b;
    e0a -> e0b;
    e0b -> e0y;

    areg -> e1a;
    g0reg -> e1a;
    bmid1 -> e1b;
    e1a -> e1b;
    e1b -> e1y;

    e0y -> em0;
    edots -> em0 [style=dashed];
    em0 -> max0;

    e1y -> em1;
    edots -> em1 [style=dashed];
    em1 -> max1;

    em0 -> emf [style=dashed];
    em1 -> emf [style=dashed];
  }

  subgraph cluster_odd {
    label="odd-bit metric and max tree";
    color="#6fa8dc";
    style="rounded";

    o0a [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    o0b [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    o0y [shape=box3d, style="filled", fillcolor="#ead1dc", label="cand u1=0"];
    o1a [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    o1b [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    o1y [shape=box3d, style="filled", fillcolor="#ead1dc", label="cand u1=1"];
    odots [shape=plaintext, label="...\n16 candidate chains total\n2 adders each"];

    om0 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    om1 [shape=diamond, style="filled", fillcolor="#f4cccc", label="MAX"];
    max2 [shape=box3d, style="filled", fillcolor="#ead1dc", label="max0_u1"];
    max3 [shape=box3d, style="filled", fillcolor="#ead1dc", label="max1_u1"];

    amid0 -> o0a;
    g1reg -> o0a;
    breg -> o0b;
    o0a -> o0b;
    o0b -> o0y;

    amid1 -> o1a;
    g1reg -> o1a;
    breg -> o1b;
    o1a -> o1b;
    o1b -> o1y;

    o0y -> om0;
    odots -> om0 [style=dashed];
    om0 -> max2;

    o1y -> om1;
    odots -> om1 [style=dashed];
    om1 -> max3;
  }

  subgraph cluster_final {
    label="posterior, extrinsic, and scale";
    color="#e69138";
    style="rounded";

    psub0 [shape=circle, style="filled", fillcolor="#fce5cd", width=0.34, fixedsize=true, label="-"];
    psub1 [shape=circle, style="filled", fillcolor="#fce5cd", width=0.34, fixedsize=true, label="-"];
    poste [shape=box3d, style="filled", fillcolor="#ead1dc", label="post_even"];
    posto [shape=box3d, style="filled", fillcolor="#ead1dc", label="post_odd"];

    esub0a [shape=circle, style="filled", fillcolor="#fce5cd", width=0.34, fixedsize=true, label="-"];
    esub0b [shape=circle, style="filled", fillcolor="#fce5cd", width=0.34, fixedsize=true, label="-"];
    esub1a [shape=circle, style="filled", fillcolor="#fce5cd", width=0.34, fixedsize=true, label="-"];
    esub1b [shape=circle, style="filled", fillcolor="#fce5cd", width=0.34, fixedsize=true, label="-"];

    sh8e [shape=box, style="rounded,filled", fillcolor="#fff2cc", label="<<3"];
    sh2e [shape=box, style="rounded,filled", fillcolor="#fff2cc", label="<<1"];
    addse0 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    addse1 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    shrte [shape=box, style="rounded,filled", fillcolor="#fff2cc", label=">>4"];
    exte [shape=box3d, style="filled", fillcolor="#ead1dc", label="ext_even"];

    sh8o [shape=box, style="rounded,filled", fillcolor="#fff2cc", label="<<3"];
    sh2o [shape=box, style="rounded,filled", fillcolor="#fff2cc", label="<<1"];
    addso0 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    addso1 [shape=circle, style="filled", fillcolor="#cfe2f3", width=0.34, fixedsize=true, label="+"];
    shrto [shape=box, style="rounded,filled", fillcolor="#fff2cc", label=">>4"];
    exto [shape=box3d, style="filled", fillcolor="#ead1dc", label="ext_odd"];

    max1 -> psub0;
    max0 -> psub0;
    psub0 -> poste;

    max3 -> psub1;
    max2 -> psub1;
    psub1 -> posto;

    poste -> esub0a;
    sysreg -> esub0a;
    esub0a -> esub0b;
    apreg -> esub0b;

    posto -> esub1a;
    sysreg -> esub1a;
    esub1a -> esub1b;
    apreg -> esub1b;

    esub0b -> sh8e;
    esub0b -> sh2e;
    esub0b -> addse0;
    sh8e -> addse0;
    sh2e -> addse1;
    addse0 -> addse1;
    esub0b -> addse1;
    addse1 -> shrte -> exte;

    esub1b -> sh8o;
    esub1b -> sh2o;
    esub1b -> addso0;
    sh8o -> addso0;
    sh2o -> addso1;
    addso0 -> addso1;
    esub1b -> addso1;
    addso1 -> shrto -> exto;
  }

  note [shape=note, style="filled", fillcolor="#fff2cc", label="Totals:\nalpha_mid: 8 repeated MAX cells\nbeta_mid: 8 repeated MAX cells\neven: 16 two-adder chains + MAX tree\nodd: 16 two-adder chains + MAX tree\nfinal: 6 subtractors + 4 scale adders"];

  exte -> note;
  exto -> note;
}
