digraph G {
  rankdir=TB;
  splines=ortho;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Gamma Metric Unit, Cell Level"];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10, color="#555555", fillcolor="#f8f6ef"];
  edge [fontname="Helvetica", fontsize=9, color="#444444"];

  in0 [label="Even-step inputs\nsys_even, par_even, apri_even\n5b, 5b, 6b", fillcolor="#d9ead3"];
  in1 [label="Odd-step inputs\nsys_odd, par_odd, apri_odd\n5b, 5b, 6b", fillcolor="#d9ead3"];

  subgraph cluster_bm0 {
    label="Branch-metric cell g0 (cell 1 of 2)";
    color="#93c47d";
    style="rounded";
    bm0pol [label="Polarity generation\nplus and minus sys/apri/par", fillcolor="#fff2cc"];
    bm0a [label="Adder A0\nsys + apri\n10b", fillcolor="#cfe2f3"];
    bm0b [label="Adder A1\n(-sys) + (-apri)\n10b", fillcolor="#cfe2f3"];
    bm0c0 [label="Adder A2\nsum_pos + par", fillcolor="#cfe2f3"];
    bm0c1 [label="Adder A3\nsum_pos + (-par)", fillcolor="#cfe2f3"];
    bm0dots [label="...\n4 second-stage adders total", fillcolor="#eeeeee"];
    bm0c3 [label="Adder A5\nsum_neg + (-par)", fillcolor="#cfe2f3"];
    bm0s0 [label="Shift by 1\nbranch g0[0]", fillcolor="#fce5cd"];
    bm0s1 [label="Shift by 1\ng0[1]", fillcolor="#fce5cd"];
    bm0sd [label="...\n4 shifters total", fillcolor="#eeeeee"];
    bm0s3 [label="Shift by 1\ng0[3]", fillcolor="#fce5cd"];
    bm0reg [label="Write local branch word\ng0_local_mem[work_local_idx]\n4 x 10b", fillcolor="#ead1dc"];
  }

  subgraph cluster_bm1 {
    label="Branch-metric cell g1 (cell 2 of 2)";
    color="#93c47d";
    style="rounded";
    bm1sum [label="Same structure as g0\n2 first-stage adders\n4 second-stage adders\n4 shifters", fillcolor="#cfe2f3"];
    bm1reg [label="Write local branch word\ng1_local_mem[work_local_idx]\n4 x 10b", fillcolor="#ead1dc"];
  }

  subgraph cluster_gamma {
    label="Pair-gamma combiner";
    color="#6fa8dc";
    style="rounded";
    gadd0 [label="Gamma adder 0\ng0[0] + g1[0]\n10b", fillcolor="#cfe2f3"];
    gadd1 [label="Gamma adder 1\ng0[0] + g1[1]\n10b", fillcolor="#cfe2f3"];
    gdots [label="...\n16 gamma adders total", fillcolor="#eeeeee"];
    gadd15 [label="Gamma adder 15\ng0[3] + g1[3]\n10b", fillcolor="#cfe2f3"];
    greg [label="Write local gamma word\ngamma_local_mem[work_local_idx]\n16 x 10b", fillcolor="#ead1dc"];
  }

  note [label="Per trellis pair totals\n2 branch-metric cells\n12 add/sub blocks\n8 shifters\n16 gamma adders", shape=note, fillcolor="#fff2cc"];

  in0 -> bm0pol;
  bm0pol -> bm0a;
  bm0pol -> bm0b;
  bm0a -> bm0c0;
  bm0a -> bm0c1;
  bm0b -> bm0dots;
  bm0b -> bm0c3;
  bm0c0 -> bm0s0;
  bm0c1 -> bm0s1;
  bm0dots -> bm0sd;
  bm0c3 -> bm0s3;
  bm0s0 -> bm0reg;
  bm0s1 -> bm0reg;
  bm0sd -> bm0reg;
  bm0s3 -> bm0reg;

  in1 -> bm1sum;
  bm1sum -> bm1reg;

  bm0reg -> gadd0;
  bm0reg -> gadd1;
  bm0reg -> gdots;
  bm0reg -> gadd15;
  bm1reg -> gadd0;
  bm1reg -> gadd1;
  bm1reg -> gdots;
  bm1reg -> gadd15;
  gadd0 -> greg;
  gadd1 -> greg;
  gdots -> greg;
  gadd15 -> greg;
  greg -> note;
}
