digraph G {
  rankdir=TB;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Index and Address Control (Updated)"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];

  setup [label="{Setup Registers|pair_cnt|win_cnt}", fillcolor="#d0e0e3"];
  idx [label="{Traversal Registers|load_idx|work_win_idx|work_local_idx}", fillcolor="#fff2cc"];
  addr0 [label="{Current Window Pair Address|work_win_idx * C_PAIR_WIN + work_local_idx}", fillcolor="#d9ead3"];
  addr1 [label="{Next Window Dummy Address|(work_win_idx + 1) * C_PAIR_WIN + work_local_idx}", fillcolor="#f4cccc"];
  outidx [label="{Output Pair Index|work_win_idx * C_PAIR_WIN + work_local_idx}", fillcolor="#fce5cd"];

  setup -> idx;
  idx -> addr0;
  idx -> addr1;
  idx -> outidx;
}
