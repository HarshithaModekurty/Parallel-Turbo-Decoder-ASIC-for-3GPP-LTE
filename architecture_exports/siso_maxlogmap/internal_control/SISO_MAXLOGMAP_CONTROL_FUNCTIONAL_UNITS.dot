digraph G {
  rankdir=LR;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Internal Control Functional Units (Updated)"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];

  setup [label="{Segment Setup|pair_cnt|win_cnt|start/end seed select}", fillcolor="#d0e0e3"];
  load [label="{Optional Load Controller|LOAD|legacy segment RAM writes}", fillcolor="#e8f0fe"];
  fetch [label="{Fetch Controller|FWD_REQ/FWD_WAIT|DUMMY_REQ/DUMMY_WAIT}", fillcolor="#fff2cc"];
  trav [label="{Window Traversal Controller|work_win_idx|work_local_idx}", fillcolor="#d9ead3"];
  roll [label="{Rolling Boundary Controller|alpha_work|beta_work|next_alpha_seed_reg}", fillcolor="#cfe2f3"];
  cache [label="{Local Cache Write Controller|alpha/g0/g1/gamma/sys/apri}", fillcolor="#cfe2f3"];
  emit [label="{Output Emit Controller|LOCAL_BWD|out_valid/out_pair_idx/done}", fillcolor="#fce5cd"];

  setup -> load;
  setup -> fetch;
  fetch -> trav;
  trav -> roll;
  roll -> cache;
  roll -> emit;
  cache -> emit;
}
