digraph G {
  rankdir=TB;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - State to Action Map (Updated)"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=10, fillcolor="#f8f6ef", color="#555555"];

  s0 [label="{IDLE|compute pair_cnt/win_cnt|select start seed|choose LOAD or FWD_REQ}", fillcolor="#d0e0e3"];
  s1 [label="{LOAD|write legacy segment RAMs|advance load_idx}", fillcolor="#e8f0fe"];
  s2 [label="{FWD_REQ/FWD_WAIT|issue/read current-window pair|latch fetched pair}", fillcolor="#fff2cc"];
  s3 [label="{FWD_STEP|compute g0/g1/gamma|store local caches|advance alpha}", fillcolor="#d9ead3"];
  s4 [label="{DUMMY_REQ/DUMMY_WAIT|issue/read next-window pair}", fillcolor="#f4cccc"];
  s5 [label="{DUMMY_STEP|backward ACS on next window|derive beta seed}", fillcolor="#f4cccc"];
  s6 [label="{LOCAL_BWD|extract_pair_precomp|emit ext/post|update beta}", fillcolor="#fce5cd"];
  s7 [label="{FINISH|pulse done}", fillcolor="#ead1dc"];

  s0 -> s1 -> s2 -> s3 -> s4 -> s5 -> s6 -> s7 [style=invis];
}
