digraph G {
  rankdir=TB;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Deep FSM Control (Updated)"];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];

  IDLE [fillcolor="#d0e0e3"];
  LOAD [fillcolor="#e8f0fe"];
  FWD_REQ [fillcolor="#fff2cc"];
  FWD_WAIT [fillcolor="#fff2cc"];
  FWD_STEP [fillcolor="#d9ead3"];
  DUMMY_REQ [fillcolor="#f4cccc"];
  DUMMY_WAIT [fillcolor="#f4cccc"];
  DUMMY_STEP [fillcolor="#f4cccc"];
  LOCAL_BWD [fillcolor="#fce5cd"];
  FINISH [fillcolor="#ead1dc"];

  IDLE -> LOAD [label="legacy mode"];
  IDLE -> FWD_REQ [label="external mode"];
  LOAD -> FWD_REQ [label="loaded"];
  FWD_REQ -> FWD_WAIT;
  FWD_REQ -> FWD_STEP [style=dashed, label="legacy RAM path"];
  FWD_WAIT -> FWD_STEP;
  FWD_STEP -> FWD_REQ [label="same window"];
  FWD_STEP -> DUMMY_REQ [label="next window exists"];
  FWD_STEP -> LOCAL_BWD [label="last window"];
  DUMMY_REQ -> DUMMY_WAIT;
  DUMMY_REQ -> DUMMY_STEP [style=dashed, label="legacy RAM path"];
  DUMMY_WAIT -> DUMMY_STEP;
  DUMMY_STEP -> DUMMY_REQ [label="continue next window"];
  DUMMY_STEP -> LOCAL_BWD [label="beta seed ready"];
  LOCAL_BWD -> LOCAL_BWD [label="next pair"];
  LOCAL_BWD -> FWD_REQ [label="advance window"];
  LOCAL_BWD -> FINISH [label="last pair"];
  FINISH -> IDLE;
}
