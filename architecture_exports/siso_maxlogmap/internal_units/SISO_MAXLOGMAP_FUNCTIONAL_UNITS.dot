digraph G {
  rankdir=TB;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Internal Functional Units (Updated)"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];
  edge [fontname="Helvetica", fontsize=10, color="#444444"];

  fetch [label="{Fetch Latch|fetched_sys/par/apri_q}", fillcolor="#fff2cc"];
  bmu [label="{Branch Metric Units|even BMU|odd BMU}", fillcolor="#d9ead3"];
  gamma [label="{Radix-4 Gamma Unit|pair_gamma_from_branches}", fillcolor="#d9ead3"];
  acs [label="{Shared ACS|forward use|dummy backward use|local backward use}", fillcolor="#cfe2f3"];
  cache [label="{Local Caches|alpha_local|g0_local|g1_local|gamma_local|sys/apri_local}", fillcolor="#cfe2f3"];
  extract [label="{Precomputed LLR Extractor|extract_pair_precomp}", fillcolor="#fce5cd"];
  format [label="{Output Formatting|metric_to_post_sat|scale_ext}", fillcolor="#ead1dc"];

  fetch -> bmu -> gamma -> acs;
  acs -> cache [label="forward store"];
  cache -> extract;
  acs -> extract [label="beta recursion"];
  extract -> format;
}
