digraph G {
  rankdir=LR;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Precomputed LLR Extraction Unit"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];

  in0 [label="{Inputs|alpha_in|beta_in}", fillcolor="#fff2cc"];
  in1 [label="{Precomputed Branch Inputs|g0|g1}", fillcolor="#fff2cc"];
  in2 [label="{Observation Inputs|sys_even/sys_odd|apri_even/apri_odd}", fillcolor="#fff2cc"];
  amid [label="{alpha_mid reconstruction}", fillcolor="#d9ead3"];
  bmid [label="{beta_mid reconstruction}", fillcolor="#d9ead3"];
  maxe [label="{Even-bit max tree|max1_u0 - max0_u0}", fillcolor="#cfe2f3"];
  maxo [label="{Odd-bit max tree|max1_u1 - max0_u1}", fillcolor="#cfe2f3"];
  post [label="{Posterior LLRs|post_even|post_odd}", fillcolor="#fce5cd"];
  ext [label="{Extrinsic Arithmetic|subtract sys/apri|scale_ext}", fillcolor="#ead1dc"];

  in0 -> amid;
  in1 -> amid;
  in0 -> bmid;
  in1 -> bmid;
  amid -> maxe;
  bmid -> maxe;
  amid -> maxo;
  bmid -> maxo;
  maxe -> post;
  maxo -> post;
  post -> ext;
  in2 -> ext;
}
