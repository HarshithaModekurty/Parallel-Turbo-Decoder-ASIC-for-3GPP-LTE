digraph G {
  rankdir=TB;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Branch and Gamma Unit (Updated)"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];

  even_in [label="{Even Inputs|sys_even|par_even|apri_even}", fillcolor="#fff2cc"];
  odd_in [label="{Odd Inputs|sys_odd|par_odd|apri_odd}", fillcolor="#fff2cc"];
  g0 [label="{Even BMU|branch_metrics|g0[0..3]}", fillcolor="#d9ead3"];
  g1 [label="{Odd BMU|branch_metrics|g1[0..3]}", fillcolor="#d9ead3"];
  gamma [label="{Gamma Combiner|pair_gamma_from_branches|gamma[0..15]}", fillcolor="#cfe2f3"];
  caches [label="{Stored Per Pair|g0_local|g1_local|gamma_local}", fillcolor="#ead1dc"];

  even_in -> g0 -> gamma;
  odd_in -> g1 -> gamma;
  g0 -> caches;
  g1 -> caches;
  gamma -> caches;
}
