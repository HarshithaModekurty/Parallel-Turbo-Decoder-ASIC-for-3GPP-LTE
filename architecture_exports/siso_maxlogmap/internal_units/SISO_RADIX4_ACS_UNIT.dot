digraph G {
  rankdir=TB;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Shared Radix-4 ACS Unit"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];

  state [label="{State Metric Input|alpha_work or beta_work}", fillcolor="#fff2cc"];
  gamma [label="{Gamma Input|gamma[0..15]}", fillcolor="#fff2cc"];
  mode [label="{Direction Select|is_backward=false : forward alpha|is_backward=true : dummy/local beta}", fillcolor="#d9ead3"];
  enum [label="{Radix-4 Trellis Enumeration|4 input pairs per state path}", fillcolor="#d9ead3"];
  reduce [label="{Metric Reduction|mod_add|mod_max / mod_max4}", fillcolor="#cfe2f3"];
  out [label="{Next State Metric Vector|alpha_next or beta_next}", fillcolor="#ead1dc"];

  state -> enum;
  gamma -> enum;
  mode -> enum;
  enum -> reduce -> out;
}
