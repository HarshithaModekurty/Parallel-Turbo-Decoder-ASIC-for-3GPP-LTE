digraph G {
  rankdir=TB;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Updated Datapath"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];
  edge [fontname="Helvetica", fontsize=10, color="#444444"];

  pair [label="{Fetched Pair|sys_even/sys_odd|par_even/par_odd|apri_even/apri_odd}", fillcolor="#fff2cc"];
  bmu0 [label="{Even BMU|branch_metrics  to  g0[0..3]}", fillcolor="#d9ead3"];
  bmu1 [label="{Odd BMU|branch_metrics  to  g1[0..3]}", fillcolor="#d9ead3"];
  gamma [label="{Radix-4 Gamma Combiner|pair_gamma_from_branches|gamma[0..15]}", fillcolor="#d9ead3"];
  acsf [label="{Forward ACS|acs_step(..., is_backward=false)}", fillcolor="#cfe2f3"];
  alpha [label="{alpha_local_mem|entering alpha per pair}", fillcolor="#cfe2f3"];
  gcache [label="{Local Branch Cache|g0_local_mem|g1_local_mem}", fillcolor="#cfe2f3"];
  gamcache [label="{Local Gamma Cache|gamma_local_mem}", fillcolor="#cfe2f3"];
  obs [label="{Local Observation Cache|sys_even/sys_odd|apri_even/apri_odd}", fillcolor="#cfe2f3"];
  acsb [label="{Backward ACS|dummy and local beta recursion}", fillcolor="#f4cccc"];
  ext [label="{extract_pair_precomp|alpha_mid|beta_mid|max trees|post/ext}", fillcolor="#fce5cd"];
  out [label="{Output Formatting|scale_ext|metric_to_post_sat}", fillcolor="#ead1dc"];

  pair -> bmu0;
  pair -> bmu1;
  bmu0 -> gamma [label="g0"];
  bmu1 -> gamma [label="g1"];
  gamma -> acsf;
  acsf -> alpha;
  bmu0 -> gcache;
  bmu1 -> gcache;
  gamma -> gamcache;
  pair -> obs;
  gamcache -> acsb [label="local backward"];
  alpha -> ext;
  gcache -> ext;
  obs -> ext;
  acsb -> ext [label="beta_in"];
  ext -> out;
}
