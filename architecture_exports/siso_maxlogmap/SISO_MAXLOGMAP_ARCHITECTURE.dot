digraph G {
  rankdir=LR;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Updated Rolling-Window Architecture"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];
  edge [fontname="Helvetica", fontsize=10, color="#444444"];

  seg [label="{Segment Setup|seg_len  to  pair_cnt, win_cnt|start_seed_v / end_seed_v}"];
  load [label="{Legacy Load Mode|LOAD state|six optional segment memories}", fillcolor="#e8f0fe"];
  fetch [label="{Pair Fetch Front-End|FWD_REQ/FWD_WAIT|DUMMY_REQ/DUMMY_WAIT|fetch_req_valid / fetch_rsp_valid}", fillcolor="#fff2cc"];
  latch [label="{Fetched Pair Latch|fetched_sys/par/apri_q}"];
  fwd [label="{Forward Step|branch_metrics x2|pair_gamma_from_branches|forward acs_step}", fillcolor="#d9ead3"];
  local [label="{Local Window Buffers|alpha_local|g0_local|g1_local|gamma_local|sys/apri_local}", fillcolor="#d9ead3"];
  carry [label="{Rolling Alpha Carry|next_alpha_seed_reg}"];
  dummy [label="{Dummy Backward Step|next-window fetch|backward acs_step}", fillcolor="#f4cccc"];
  llr [label="{Local Backward + LLR Extraction|extract_pair_precomp|beta update|out_valid/post/ext}", fillcolor="#fce5cd"];
  out [label="{Outputs|out_pair_idx|ext_even/ext_odd|post_even/post_odd|done}", fillcolor="#ead1dc"];
  fsm [label="{FSM|IDLE|LOAD|FWD_REQ/FWD_WAIT/FWD_STEP|DUMMY_REQ/DUMMY_WAIT/DUMMY_STEP|LOCAL_BWD|FINISH}", fillcolor="#d0e0e3"];

  seg -> load [label="legacy mode"];
  seg -> fetch [label="external mode"];
  load -> fetch [style=dashed, label="pair read"];
  fetch -> latch;
  latch -> fwd;
  fwd -> local [label="store local context"];
  fwd -> carry [label="end-alpha"];
  carry -> fwd [label="next window alpha start", style=dashed];
  fwd -> dummy [label="if next window exists"];
  dummy -> llr [label="beta seed for current window"];
  fwd -> llr [label="last window uses end_seed", style=dashed];
  local -> llr [label="alpha/g0/g1/gamma/sys/apri"];
  llr -> out;
  fsm -> load [dir=none, style=dotted];
  fsm -> fetch [dir=none, style=dotted];
  fsm -> fwd [dir=none, style=dotted];
  fsm -> dummy [dir=none, style=dotted];
  fsm -> llr [dir=none, style=dotted];
}
