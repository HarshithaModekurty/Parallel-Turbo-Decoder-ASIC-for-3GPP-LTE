digraph G {
  rankdir=TB;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="siso_maxlogmap - Updated Control / FSM"];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];
  edge [fontname="Helvetica", fontsize=10, color="#444444"];

  IDLE [fillcolor="#d0e0e3"];
  LOAD [fillcolor="#e8f0fe", label="LOAD\n(optional legacy preload)"];
  FWD_REQ [fillcolor="#fff2cc"];
  FWD_WAIT [fillcolor="#fff2cc"];
  FWD_STEP [fillcolor="#d9ead3", label="FWD_STEP\ncompute/store g0 g1 gamma\nadvance alpha"];
  DUMMY_REQ [fillcolor="#f4cccc"];
  DUMMY_WAIT [fillcolor="#f4cccc"];
  DUMMY_STEP [fillcolor="#f4cccc", label="DUMMY_STEP\nnext-window beta seed"];
  LOCAL_BWD [fillcolor="#fce5cd", label="LOCAL_BWD\nemit post/ext\nupdate beta"];
  FINISH [fillcolor="#ead1dc"];

  IDLE -> LOAD [label="start & !G_USE_EXTERNAL_FETCH"];
  IDLE -> FWD_REQ [label="start & G_USE_EXTERNAL_FETCH"];
  LOAD -> FWD_REQ [label="last pair loaded"];
  FWD_REQ -> FWD_WAIT [label="external fetch"];
  FWD_REQ -> FWD_STEP [label="legacy RAM read"];
  FWD_WAIT -> FWD_STEP [label="fetch_rsp_valid"];
  FWD_STEP -> FWD_REQ [label="next pair in current window"];
  FWD_STEP -> DUMMY_REQ [label="window done, next window exists"];
  FWD_STEP -> LOCAL_BWD [label="last window"];
  DUMMY_REQ -> DUMMY_WAIT [label="external fetch"];
  DUMMY_REQ -> DUMMY_STEP [label="legacy RAM read"];
  DUMMY_WAIT -> DUMMY_STEP [label="fetch_rsp_valid"];
  DUMMY_STEP -> DUMMY_REQ [label="more next-window pairs"];
  DUMMY_STEP -> LOCAL_BWD [label="beta seed ready"];
  LOCAL_BWD -> LOCAL_BWD [label="next older pair"];
  LOCAL_BWD -> FWD_REQ [label="window done, advance to next window"];
  LOCAL_BWD -> FINISH [label="last output pair"];
  FINISH -> IDLE;
}
