digraph turbo_parallel8_control {
  graph [
    rankdir=TB,
    splines=polyline,
    nodesep=0.4,
    ranksep=0.6,
    pad=0.2,
    bgcolor="white",
    fontname="Helvetica",
    labelloc="t",
    label="turbo_decoder_top_parallel8_backup Control / Schedule"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="white",
    color="#334155",
    fontname="Helvetica",
    fontsize=10,
    margin="0.10,0.06"
  ];

  edge [
    color="#475569",
    arrowsize=0.7,
    penwidth=1.1,
    fontname="Helvetica",
    fontsize=9
  ];

  inputs [label="Top Inputs\nstart\nn_half_iter\nk_len\nin_valid / in_idx", fillcolor="#F8FAFC"];
  outputs [label="Top Outputs\nout_valid\nout_idx\ndone", fillcolor="#F8FAFC"];

  subgraph cluster_iter {
    label="turbo_iteration_ctrl";
    color="#93C5FD";
    style="rounded";

    idle [label="IDLE", fillcolor="#EFF6FF"];
    run1 [label="RUN1", fillcolor="#EFF6FF"];
    run2 [label="RUN2", fillcolor="#EFF6FF"];
    finish [label="FINISH", fillcolor="#EFF6FF"];
  }

  subgraph cluster_sched {
    label="Main Top-Level Scheduler";
    color="#BFDBFE";
    style="rounded";

    init [label="Start Capture\nframe_bits <= K\nseg_bits <= K/8\npair_count <= ceil(seg_bits/2)\nfirst_run1_pending <= 1", fillcolor="#F8FBFF"];
    run_edge [label="Run Edge Actions\nissue_active <= 1\nissue_pair_idx <= 0\npulse core_start[0:7]\ncore_seg_len <= seg_bits", fillcolor="#F8FBFF"];
    issue_loop [label="Issue Loop\nstep pair_row 0..pair_count-1\ntrigger memory reads", fillcolor="#F8FBFF"];
    feed_pipe [label="Feed Pipe\nfeed_pipe_valid\ncore_in_valid[0:7]\ncore_in_pair_idx", fillcolor="#F8FBFF"];
    all_done [label="Lane Completion Check\nassert output alignment\nall_done = AND(core_done)", fillcolor="#F8FBFF"];
    phase_done [label="phase1_done / phase2_done\nback to iteration controller", fillcolor="#F8FBFF"];
    ser_start [label="If last_half and all_done\nser_issue_active <= 1\nser_issue_idx <= 0", fillcolor="#F8FBFF"];
    ser_loop [label="Serializer Loop\nser_issue_idx 0..K-1\nselect lane / row / parity\nemit out_valid + out_idx", fillcolor="#F8FBFF"];
  }

  subgraph cluster_side {
    label="Controlled Actions";
    color="#A7F3D0";
    style="rounded";

    load_proc [label="Input Load Process\nscatter scalar load into lane memories", fillcolor="#F0FDF4"];
    run1_actions [label="RUN1 feed\nsys/par1/ext-or-zero", fillcolor="#F0FDF4"];
    run2_actions [label="RUN2 feed\nQPP + Batcher route\nstore perm history", fillcolor="#F0FDF4"];
    wb_proc [label="Writeback Process\nrun1 direct\nrun2 unslaved\nwrite ext/final", fillcolor="#F0FDF4"];
  }

  note0 [shape=note, fillcolor="#FEFCE8", color="#EAB308", label="Top has no explicit local FSM enum.\nControl = turbo_iteration_ctrl\n+ sequential scheduler process."];
  note1 [shape=note, fillcolor="#FEF2F2", color="#F87171", label="first_run1_pending:\nfirst RUN1 uses zero apriori,\nlater RUN1 uses stored extrinsic."];

  inputs -> load_proc [style=dashed, color="#2563EB", label="external frame load"];
  inputs -> idle [style=dashed, color="#2563EB", label="start"];
  inputs -> init [style=dashed, color="#2563EB", label="k_len"];

  idle -> run1 [label="start and n_half_iter > 0"];
  idle -> finish [label="start and n_half_iter = 0"];
  run1 -> run2 [label="phase1_done and not last_half"];
  run1 -> finish [label="phase1_done and last_half"];
  run2 -> run1 [label="phase2_done and not last_half"];
  run2 -> finish [label="phase2_done and last_half"];
  finish -> idle [label="next cycle"];

  run1 -> run_edge [style=dashed, color="#2563EB", label="rising edge of run1"];
  run2 -> run_edge [style=dashed, color="#2563EB", label="rising edge of run2"];
  init -> run_edge [style=dashed, color="#2563EB", label="initialized counts"];
  run_edge -> issue_loop;
  issue_loop -> feed_pipe [label="one cycle later"];
  feed_pipe -> all_done [label="cores running in parallel"];
  all_done -> phase_done [label="all cores done"];

  run1 -> run1_actions [style=dashed, color="#2563EB", label="mode=run1"];
  run2 -> run2_actions [style=dashed, color="#2563EB", label="mode=run2"];
  run1_actions -> feed_pipe [style=dashed, color="#2563EB", label="direct feed"];
  run2_actions -> feed_pipe [style=dashed, color="#2563EB", label="routed feed"];
  feed_pipe -> wb_proc [style=dashed, color="#2563EB", label="outputs later return from SISOs"];
  all_done -> wb_proc [style=dashed, color="#2563EB", label="writeback completed by pair stream"];

  phase_done -> run1 [style=dashed, color="#2563EB", label="controller handshake"];
  phase_done -> run2 [style=dashed, color="#2563EB", label="controller handshake"];
  phase_done -> ser_start [style=dashed, color="#2563EB", label="if last_half"];
  ser_start -> ser_loop;
  ser_loop -> outputs [label="serialized posterior stream"];
  finish -> outputs [style=dashed, color="#2563EB", label="done pulse"];

  note0 -> run_edge [style=dotted, arrowhead=none, color="#A16207"];
  note1 -> run1_actions [style=dotted, arrowhead=none, color="#DC2626"];
}
