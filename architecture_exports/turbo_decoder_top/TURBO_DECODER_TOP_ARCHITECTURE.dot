digraph G {
  rankdir=LR;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="turbo_decoder_top - Active Folded Architecture"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];
  edge [fontname="Helvetica", fontsize=10, color="#444444"];

  input [label="{Input Loader|in_valid / in_idx|l_sys_in|l_par1_in|l_par2_in}", fillcolor="#fff2cc"];
  chan [label="{Channel BRAM Bank|SYS_NAT_E/O|PAR1_NAT_E/O|SYS_INT_E/O|PAR2_INT_E/O}", fillcolor="#d9ead3"];
  ext [label="{Extrinsic BRAM Bank|EXT_NAT_E/O|EXT_INT_E/O}", fillcolor="#d9ead3"];
  post [label="{Posterior BRAM Bank|POST_INT_E/O|FINAL_NAT_E/O}", fillcolor="#d9ead3"];
  qpp [label="{QPP / Permutation Engine|qpp_curr_i|qpp_delta_i|qpp_step_i}", fillcolor="#cfe2f3"];
  fetch [label="{SISO Fetch Service|request pair from BRAMs|return sys/par/apri}", fillcolor="#cfe2f3"];
  siso [label="{Single SISO Core|siso_maxlogmap|G_USE_EXTERNAL_FETCH=true}", fillcolor="#fce5cd"];
  wb [label="{Run Writeback|EXT_NAT / EXT_INT|POST_INT / FINAL_NAT}", fillcolor="#ead1dc"];
  ser [label="{Final Serializer|FINAL_NAT_E/O  to  out_idx/l_post}", fillcolor="#ead1dc"];
  fsm [label="{Top FSM|IDLE|BUILD_SYS_INT|START_RUN|WAIT_RUN|EXT permutations|SERIALIZE|FINISH}", fillcolor="#d0e0e3"];

  input -> chan;
  input -> ext;
  input -> post;
  chan -> qpp [label="build SYS_INT / permute"];
  ext -> qpp [label="permute ext"];
  qpp -> chan [label="write SYS_INT"];
  qpp -> ext [label="write permuted EXT"];
  chan -> fetch;
  ext -> fetch;
  fetch -> siso;
  siso -> wb;
  wb -> ext;
  wb -> post;
  post -> ser;
  ser -> fsm [style=dotted, dir=none];
  fsm -> qpp [dir=none, style=dotted];
  fsm -> fetch [dir=none, style=dotted];
  fsm -> wb [dir=none, style=dotted];
}
