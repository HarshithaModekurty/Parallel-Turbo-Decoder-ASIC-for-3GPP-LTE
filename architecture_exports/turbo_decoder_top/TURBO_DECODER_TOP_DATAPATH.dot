digraph G {
  rankdir=LR;
  graph [labelloc=t, fontsize=20, fontname="Helvetica", label="turbo_decoder_top - Active Folded Datapath"];
  node [shape=record, style="rounded,filled", fontname="Helvetica", fontsize=11, fillcolor="#f8f6ef", color="#555555"];

  inload [label="{Input Load Path|natural sys/par1|interleaved par2|zero ext/post init}", fillcolor="#fff2cc"];
  natmem [label="{Natural-Domain Memories|SYS_NAT|PAR1_NAT|EXT_NAT}", fillcolor="#d9ead3"];
  intmem [label="{Interleaved-Domain Memories|SYS_INT|PAR2_INT|EXT_INT|POST_INT}", fillcolor="#d9ead3"];
  qpp [label="{Incremental QPP Path|build SYS_INT|permute ext/post}", fillcolor="#cfe2f3"];
  fetch [label="{On-Demand Fetch Responder|BRAM read issue|response pipeline}", fillcolor="#cfe2f3"];
  siso [label="{siso_u|natural run or interleaved run}", fillcolor="#fce5cd"];
  final [label="{FINAL_NAT Memories + Serializer}", fillcolor="#ead1dc"];

  inload -> natmem;
  inload -> intmem;
  natmem -> qpp;
  qpp -> intmem [label="SYS_INT / EXT_INT"];
  intmem -> qpp [label="EXT_INT / POST_INT"];
  qpp -> natmem [label="EXT_NAT / FINAL_NAT"];
  natmem -> fetch;
  intmem -> fetch;
  fetch -> siso;
  siso -> natmem [label="EXT_NAT"];
  siso -> intmem [label="EXT_INT / POST_INT"];
  siso -> final [label="FINAL_NAT on last natural run"];
}
